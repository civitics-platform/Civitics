{
  "name": "civitics",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "fixes:sync": "node scripts/fixes-sync.mjs",
    "fixes:sync:dry": "node scripts/fixes-sync.mjs --dry-run",
    "fixes:check": "node scripts/fixes-sync.mjs --check",
    "fixes:housekeep": "node scripts/fixes-housekeep.mjs",
    "fixes:housekeep:dry": "node scripts/fixes-housekeep.mjs --dry-run",
    "fixes:clean": "node scripts/fixes-clean.mjs",
    "fixes:clean:dry": "node scripts/fixes-clean.mjs --dry-run",
    "fixes:archive": "node scripts/fixes-archive.mjs",
    "fixes:archive:dry": "node scripts/fixes-archive.mjs --dry-run"
  },
  "devDependencies": {
    "supabase": "latest",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "supabase"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
