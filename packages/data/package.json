    "data:districts": "tsx --env-file=../../.env.local src/pipelines/districts-tiger/index.ts",
    "data:connections": "tsx --env-file=../../.env.local src/pipelines/connections/index.ts",
    "data:pilot-metros": "tsx --env-file=../../.env.local src/jurisdictions/pilot-metros.ts",
    "data:legistar": "tsx --env-file=../../.env.local src/pipelines/legistar/index.ts",
