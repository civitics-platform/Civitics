    "data:sync": "tsx --env-file=../../.env.local src/pipelines/index.ts",
    "data:status": "tsx --env-file=../../.env.local src/pipelines/index.ts status",
    "data:regulations": "tsx --env-file=../../.env.local src/pipelines/regulations/index.ts",
    "data:fec-bulk": "tsx --env-file=../../.env.local src/pipelines/fec-bulk/index.ts",
