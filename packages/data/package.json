    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.10",
    "@types/shapefile": "^0.6.4",
    "@types/unzipper": "^0.10.9",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
